.DS_Store
__pycache__/
*.pyc
*.pyo
*.log
*.tmp
*.swp
.env
.venv/
venv/

# 依赖（跨平台原生模块，不进仓库，首次运行由 launch-viewer 自动安装）
node_modules/

# viewer 本地运行状态（密钥缓存、连接状态等）
.viewer_status/
.viewer_key*
.viewer_key.json
.viewer_cache/

# Frida 内存扫描产物（链接/库 dump，不进仓库）
scripts/frida_route/output/

# 客户本地配置（每台机器不同，不进仓库；首次运行由向导生成）
scripts/config.json
scripts/wechat_key.txt
