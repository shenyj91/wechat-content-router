{
  "vault_root": "/Users/yourname/Documents/ObsidianVault",
  "state_file": "/Users/yourname/Documents/ObsidianVault/.wechat-content-router-state.json",
  "storage": {
    "mode": "obsidian",
    "local_root": "/Users/yourname/Documents/ImportedContent"
  },
  "settings": {
    "openAfterCreate": false,
    "downloadImages": true,
    "runOcr": true,
    "keepImagesInNote": true,
    "deleteImagesAfterOcr": false,
    "appendImagesAfterText": true,
    "includeFrontmatter": true,
    "includeImportedAt": true
  },
  "routes": {
    "xhs": {
      "enabled": true,
      "import_root": "微信导入/小红书",
      "asset_root": "微信导入/小红书/assets"
    },
    "mp": {
      "enabled": true,
      "import_root": "微信导入/公众号",
      "save_pdf": false,
      "prefer_pdf_preview": false,
      "pdf_source": "browser_render"
    },
    "feishu": {
      "enabled": false,
      "import_root": "微信导入/飞书",
      "save_pdf": true,
      "prefer_pdf_preview": true,
      "pdf_source": "browser_render"
    }
  },
  "wechat": {
    "enabled": false,
    "session_db": "/absolute/path/to/session.db",
    "message_dir": "/absolute/path/to/decrypted/message",
    "chat_username": "filehelper",
    "message_table": "",
    "decrypt_workdir": "/absolute/path/to/wechat-decrypt",
    "decrypt_python": "/absolute/path/to/python3",
    "decrypt_script": "/absolute/path/to/decrypt_db.py"
  }
}
